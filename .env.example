PORT=3000

# Postgres connection — Prisma reads from prisma.config.ts
DATABASE_URL=postgresql://user:pass@localhost:5432/kashbook

JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
# AES-256-GCM key for at-rest PII encryption (BVN, CAC). Generate fresh per env.
#   openssl rand -hex 32
ENCRYPTION_KEY=change_to_64_hex_chars_32_random_bytes

# Termii — Nigerian SMS provider. Sign up at termii.com → API keys.
# Sender ID approval takes ~24h. Until approved, Termii uses "N-Alert" as the sender.
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=KashBook

# Africa's Talking — default SMS provider for all countries (the SMS router
# falls back to this). Username = the app slug in your dashboard URL
# (account.africastalking.com/apps/<username>). Generate the key under Settings.
AFRICAS_TALKING_USER=your_at_username
AFRICAS_TALKING_KEY=atsk_xxx
# Optional REGISTERED sender ID (leave unset to use AT's default sender):
# AFRICAS_TALKING_SENDER=
# Optional sandbox endpoint:
# AFRICAS_TALKING_BASE=https://api.sandbox.africastalking.com/version1/messaging

# Email — Gmail App Password or any SMTP provider (used for OTP + general mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="KashBook <your@gmail.com>"

# Brand logo shown in email headers. Set ONE of these so the logo loads (email
# clients can't show a local/relative image):
#   EMAIL_LOGO_URL  — full https URL to the logo (takes priority), OR
#   PUBLIC_BASE_URL — the server's public base; the logo is served at
#                     <PUBLIC_BASE_URL>/email-logo.png (from server/public/).
# If neither is set, emails fall back to a CSS-drawn mark (no broken image).
EMAIL_LOGO_URL=
PUBLIC_BASE_URL=

# Transaction alert emails (debit/credit). Dedicated mailbox so they don't share
# the OTP sender. If unset, falls back to the SMTP_* values above. If neither is
# set, transaction emails are silently skipped.
TXN_SMTP_HOST=mail.relianttechnology.com.ng
TXN_SMTP_PORT=587
TXN_SMTP_USER=transaction@relianttechnology.com.ng
TXN_SMTP_PASS=your_transaction_mailbox_password
TXN_EMAIL_FROM="KashBook <transaction@relianttechnology.com.ng>"

# Anchor (BaaS) — virtual accounts + transfers
# Sandbox: https://api.sandbox.getanchor.co/api/v1
# Live:    https://api.getanchor.co/api/v1
ANCHOR_BASE_URL=https://api.sandbox.getanchor.co/api/v1
ANCHOR_API_KEY=your_anchor_api_key
ANCHOR_WEBHOOK_SECRET=signing_secret_from_anchor_webhook_config
# KashBook's revenue DepositAccount at Anchor. Outbound-transfer fees
# (₦51 / ₦101 above ₦10k) are book-transferred into it after each NIP
# payout. LEAVE EMPTY TO DISABLE FEES — quotes return ₦0, nothing is
# collected, transfers behave as before.
ANCHOR_FEE_ACCOUNT_ID=

# Cloudinary — image uploads (avatars, business logos)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# RevenueCat webhook — the Authorization header value you set under
# Project settings → Integrations → Webhooks. Any long random string;
# it must match exactly. Keeps User.plan in sync with subscriptions.
REVENUECAT_WEBHOOK_AUTH=long_random_shared_secret

# ── KYC pre-Anchor validation (Dojah + Google geocoding) ────────────────────
# Backing provider for BVN + CAC lookups. Today the only adapter is "dojah".
KYC_PROVIDER=dojah
# Dojah credentials (Developers → Configuration → My Apps in the dashboard).
# Secret key is server-only; never goes into the React Native bundle.
DOJAH_APP_ID=your_dojah_app_id
DOJAH_SECRET_KEY=your_dojah_secret_key
# Base URL — sandbox is the safe default. Flip to https://api.dojah.io for prod.
DOJAH_BASE_URL=https://sandbox.dojah.io
# Cache TTL for KycCheckCache rows. NDPA-minimisation cap defaults to 24h.
KYC_CACHE_TTL_HOURS=24
# Rate limits on failed-attempt counters per 24h sliding window.
KYC_USER_MAX_ATTEMPTS_PER_DAY=3
KYC_VALUE_MAX_ATTEMPTS_PER_DAY=5

# ── Error tracking (Sentry) ─────────────────────────────────────────────────
# DSN for the "node" Sentry project (Settings -> Projects -> node -> Client Keys).
# Empty -> Sentry disabled (no error reporting). DSNs are publishable / safe.
SENTRY_DSN=
# Optional. Environment tag + perf-trace sample rate (0..1). Defaults: NODE_ENV, 0.1.
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Instagram DMs (Phase 3 — "Instagram API with Instagram Login") ───────────
# Lets merchants connect their own IG Professional account to read/reply to DMs
# and send their NUBAN payment details. EMPTY → the feature degrades gracefully
# (connect returns 503, no routes activate). Requires Meta App Review + Business
# Verification before it works for non-test accounts. See docs/INSTAGRAM_API_SPEC.md
# and docs/INSTAGRAM_META_SETUP.md.
#
# Instagram App ID + Secret — Meta App Dashboard → Instagram product → API setup
# with Instagram login. NOT the Facebook App ID. The secret is server-only and
# also keys the webhook X-Hub-Signature-256 HMAC.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Webhook verify token — any long random string; must match the value you enter
# in the Meta webhook config for the GET handshake.
IG_VERIFY_TOKEN=
# Optional overrides:
#   IG_REDIRECT_URI  — defaults to <PUBLIC_BASE_URL>/instagram/callback (must be
#                      registered EXACTLY as an OAuth redirect URI in the app).
#   IG_API_VERSION   — default v25.0
#   IG_SCOPES        — default instagram_business_basic,instagram_business_manage_messages
IG_REDIRECT_URI=
IG_API_VERSION=v25.0
IG_SCOPES=instagram_business_basic,instagram_business_manage_messages

# ── WhatsApp Business (per-merchant Cloud API via Embedded Signup) ────────────
# Lets merchants connect their own WhatsApp Business number (dedicated number
# today; existing-app numbers once Meta's Coexistence reaches Nigeria). EMPTY →
# graceful 503. Distinct from the WHATSAPP_* vars above (KashBook's own OTP
# number). See docs/WHATSAPP_API_SPEC.md.
#
# The FACEBOOK app id + secret (the "Bookkeeping" app — NOT the Instagram app
# id/secret). The secret also keys the /webhooks/whatsapp HMAC.
META_APP_ID=
META_APP_SECRET=
# Embedded Signup configuration id (Facebook Login for Business → Configurations).
WA_CONFIG_ID=
# Webhook verify token for the WhatsApp product's webhook config.
WA_VERIFY_TOKEN=
WA_API_VERSION=v25.0

NODE_ENV=development
