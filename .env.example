PORT=3000

# Postgres connection — Prisma reads from prisma.config.ts
DATABASE_URL=postgresql://user:pass@localhost:5432/kashbook

JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
# AES-256-GCM key for at-rest PII encryption (BVN, CAC). Generate fresh per env.
#   openssl rand -hex 32
ENCRYPTION_KEY=change_to_64_hex_chars_32_random_bytes
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Termii — Nigerian SMS provider. Sign up at termii.com → API keys.
# Sender ID approval takes ~24h. Until approved, Termii uses "N-Alert" as the sender.
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=KashBook

# Email — Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="KashBook <your@gmail.com>"

# Anchor (BaaS) — virtual accounts + transfers
# Sandbox: https://api.sandbox.getanchor.co/api/v1
# Live:    https://api.getanchor.co/api/v1
ANCHOR_BASE_URL=https://api.sandbox.getanchor.co/api/v1
ANCHOR_API_KEY=your_anchor_api_key
ANCHOR_WEBHOOK_SECRET=signing_secret_from_anchor_webhook_config

# Cloudinary — image uploads (avatars, business logos)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

NODE_ENV=development
