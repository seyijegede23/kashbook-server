PORT=3000

# Postgres connection — Prisma reads from prisma.config.ts
DATABASE_URL=postgresql://user:pass@localhost:5432/kashbook

JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
# AES-256-GCM key for at-rest PII encryption (BVN, CAC). Generate fresh per env.
#   openssl rand -hex 32
ENCRYPTION_KEY=change_to_64_hex_chars_32_random_bytes

# Termii — Nigerian SMS provider. Sign up at termii.com → API keys.
# Sender ID approval takes ~24h. Until approved, Termii uses "N-Alert" as the sender.
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=KashBook

# Email — Gmail App Password or any SMTP provider (used for OTP + general mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="KashBook <your@gmail.com>"

# Transaction alert emails (debit/credit). Dedicated mailbox so they don't share
# the OTP sender. If unset, falls back to the SMTP_* values above. If neither is
# set, transaction emails are silently skipped.
TXN_SMTP_HOST=mail.relianttechnology.com.ng
TXN_SMTP_PORT=587
TXN_SMTP_USER=transaction@relianttechnology.com.ng
TXN_SMTP_PASS=your_transaction_mailbox_password
TXN_EMAIL_FROM="KashBook <transaction@relianttechnology.com.ng>"

# Anchor (BaaS) — virtual accounts + transfers
# Sandbox: https://api.sandbox.getanchor.co/api/v1
# Live:    https://api.getanchor.co/api/v1
ANCHOR_BASE_URL=https://api.sandbox.getanchor.co/api/v1
ANCHOR_API_KEY=your_anchor_api_key
ANCHOR_WEBHOOK_SECRET=signing_secret_from_anchor_webhook_config
# KashBook's revenue DepositAccount at Anchor. Outbound-transfer fees
# (₦51 / ₦101 above ₦10k) are book-transferred into it after each NIP
# payout. LEAVE EMPTY TO DISABLE FEES — quotes return ₦0, nothing is
# collected, transfers behave as before.
ANCHOR_FEE_ACCOUNT_ID=

# Cloudinary — image uploads (avatars, business logos)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# RevenueCat webhook — the Authorization header value you set under
# Project settings → Integrations → Webhooks. Any long random string;
# it must match exactly. Keeps User.plan in sync with subscriptions.
REVENUECAT_WEBHOOK_AUTH=long_random_shared_secret

# ── KYC pre-Anchor validation (Dojah + Google geocoding) ────────────────────
# Backing provider for BVN + CAC lookups. Today the only adapter is "dojah".
KYC_PROVIDER=dojah
# Dojah credentials (Developers → Configuration → My Apps in the dashboard).
# Secret key is server-only; never goes into the React Native bundle.
DOJAH_APP_ID=your_dojah_app_id
DOJAH_SECRET_KEY=your_dojah_secret_key
# Base URL — sandbox is the safe default. Flip to https://api.dojah.io for prod.
DOJAH_BASE_URL=https://sandbox.dojah.io
# Cache TTL for KycCheckCache rows. NDPA-minimisation cap defaults to 24h.
KYC_CACHE_TTL_HOURS=24
# Rate limits on failed-attempt counters per 24h sliding window.
KYC_USER_MAX_ATTEMPTS_PER_DAY=3
KYC_VALUE_MAX_ATTEMPTS_PER_DAY=5

# ── Error tracking (Sentry) ─────────────────────────────────────────────────
# DSN for the "node" Sentry project (Settings -> Projects -> node -> Client Keys).
# Empty -> Sentry disabled (no error reporting). DSNs are publishable / safe.
SENTRY_DSN=
# Optional. Environment tag + perf-trace sample rate (0..1). Defaults: NODE_ENV, 0.1.
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

NODE_ENV=development
