generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String         @id @default(uuid())
  firstName            String
  lastName             String
  businessName         String
  phone                String?        @unique
  email                String?        @unique
  password             String?
  plan                 Plan           @default(FREE)
  role                 Role           @default(USER)
  accountType          AccountType    @default(OWNER)
  employerId           String?
  profileImage         String?        @db.Text
  avatarUrl            String?
  expoPushToken        String?
  country              String         @default("NG")  // ISO 3166-1 alpha-2 — drives currency, language, calling code, KYC, AML
  language             String         @default("en")
  currency             String         @default("NGN")  // derived from country at write-time
  notificationsEnabled Boolean        @default(true)
  biometricEnabled     Boolean        @default(false)
  autoDebitEnabled     Boolean        @default(true)   // global kill-switch for all recurring auto-debits
  transactionPin             String?
  transactionPinFailedCount  Int       @default(0)
  transactionPinLockedUntil  DateTime?
  failedLoginAttempts  Int            @default(0)
  lockedUntil          DateTime?
  dateOfBirth          DateTime?
  gender               String?
  anchorCustomerId     String?        @unique
  paystackCustomerCode String?
  kycStatus            String         @default("unverified")
  accountStatus        String         @default("active")  // "active" | "restricted" | "frozen" | "closed"
  complianceFreezeReason String?
  complianceFrozenAt   DateTime?
  complianceFrozenBy   String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  businesses           Business[]
  customers            Customer[]
  transactions         Transaction[]
  sales                Sales[]
  expenses             Expense[]
  businessDebts        BusinessDebt[]
  suggestions          Suggestion[]
  reminders            Reminder[]
  inventoryItems       InventoryItem[]
  notifications        AppNotification[]
  recurringExpenses    RecurringExpense[]
}

model AppNotification {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, read])
}

model Business {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  name             String
  emoji            String          @default("🛍️")
  color            String          @default("#6C3FC5")
  logoUrl          String?
  receiptFooter    String?
  invoiceTemplate  String          @default("classic")
  bankName         String?
  bankAccountNumber String?
  bankAccountName  String?
  usePaymentOverride Boolean       @default(false)
  riskCategory     String          @default("standard") // "standard" | "elevated" | "high"
  accountStatus    String          @default("active")   // "active" | "restricted" | "frozen" | "closed"
  country          String          @default("NG")       // immutable after creation; drives currency + KYC + AML + banking
  baseCurrency     String          @default("NGN")      // locked to country; dashboard / cash totals / AML thresholds read this
  kycId            String?                              // generic primary KYC identifier (encrypted)
  kycIdType        String          @default("BVN")      // "BVN" | "GhanaCard" | "KE_NID" | "SA_ID" | "EG_NID" | "UG_NIN"
  invoiceCounter       Int             @default(0)
  taxId                String?                              // display-only Tax ID / RC number for documents (P&L, invoices)
  virtualAccountRef    String?
  virtualAccountId     String?
  virtualAccountNumber String?
  virtualAccountBank   String?
  virtualAccountName   String?
  anchorAccountId      String?
  paystackDvaId        String?
  bankAccountType      String          @default("SAVINGS")
  kycBvn               String?
  kycCacNumber         String?
  // HMAC-SHA-256 fingerprints of the encrypted identifiers above. Searchable,
  // irreversible — used for dedup ("has anyone else registered this BVN/CAC")
  // and for the KycCheckCache lookup. See server/src/utils/crypto.js hmacValue().
  kycBvnHash           String?  @db.VarChar(64)
  kycCacHash           String?  @db.VarChar(64)
  kycBusinessType      String?  @default("sole_proprietor")
  cacCertificateUrl    String?
  description          String?
  industry             String?
  registrationType     String?
  dateOfRegistration   DateTime?
  dateOfIncorporation  DateTime?
  addressState         String?
  addressLine1         String?
  addressLine2         String?
  addressCity          String?
  addressPostalCode    String?
  directorAddressSame  Boolean  @default(true)
  directorAddressLine1 String?
  directorAddressState String?
  directorAddressCity  String?
  // VAT summary settings. Off by default (most micro-traders aren't VAT-
  // registered). vatRate null → country default. vatInclusive: are recorded
  // amounts treated as VAT-inclusive (true, NG default) or exclusive.
  vatEnabled           Boolean         @default(false)
  vatRate              Float?
  vatInclusive         Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  transactions      Transaction[]
  sales             Sales[]
  expenses          Expense[]
  businessDebts     BusinessDebt[]
  customCategories  CustomCategory[]
  inventoryItems    InventoryItem[]
  customers         Customer[]
  reminders         Reminder[]
  payables          Payable[]
  invoices          Invoice[]
  recurringExpenses RecurringExpense[]
  officers          BusinessOfficer[]
  beneficiaries     Beneficiary[]

  @@index([userId])
  @@index([virtualAccountRef])
  @@index([kycBvnHash])
  @@index([kycCacHash])
}

// Saved transfer recipients — powers the "Recents" chips on Send Money so a
// repeat transfer starts from one tap instead of bank-search + 10 digits.
// Upserted on every successful outbound transfer.
model Beneficiary {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  accountNumber String
  bankCode      String
  bankName      String?
  accountName   String?
  timesUsed     Int      @default(1)
  lastUsedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([businessId, accountNumber, bankCode])
  @@index([businessId, lastUsedAt])
}

model BusinessOfficer {
  id                String   @id @default(uuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role              String   // "DIRECTOR" | "OWNER"
  firstName         String
  lastName          String
  middleName        String?
  bvn               String   // encrypted via utils/crypto.js — re-used as the ID value field; idType disambiguates
  // HMAC-SHA-256 fingerprint of the encrypted bvn above. Searchable, irreversible.
  // Used for officer-level BVN dedup ("this person is already a director of
  // another KashBook business"). See server/src/utils/crypto.js hmacValue().
  bvnHash           String?  @db.VarChar(64)
  idType            String   @default("BVN") // "BVN" | "GhanaCard" | "KE_NID" | "SA_ID" | "EG_NID" | "UG_NIN"
  dateOfBirth       DateTime
  gender            String   // "Male" | "Female"
  email             String?
  phoneNumber       String?
  nationality       String   @default("NG")
  title             String   @default("President")
  percentageOwned   Float    @default(0)
  addressLine1      String?
  addressLine2      String?
  addressCity       String?
  addressState      String?
  addressPostalCode String?
  addressCountry    String   @default("NG")
  createdAt         DateTime @default(now())

  @@index([businessId])
  @@index([bvnHash])
}

// ─────────────────────────────────────────────────────────────────────────────
// KYC pre-Anchor validation models. See server/src/utils/kycCheck.js.
//
// KycCheckAttempt   — append-only audit + rate-limit ledger. One row per
//                     attempted check of any type (bvn / cac / address / …).
// KycCheckCache     — successful Phase C / D responses, 24h TTL enforced in
//                     code via a daily purge cron. No plaintext PII; the
//                     result JSON is the provider's normalised response.
// ─────────────────────────────────────────────────────────────────────────────
model KycCheckAttempt {
  id            String   @id @default(cuid())
  userId        String
  checkType     String   // "bvn" | "cac" | "address" | future: "nin" | …
  // SHA-256/HMAC hash of the checked value. For "address" it's a hash of the
  // normalised line1+city+state — lets us dedupe geocoding requests.
  valueHash     String   @db.VarChar(64)
  result        String   // see kycCheck.js for the full enum
  provider      String?  // "dojah" | "google" | null for cheap-layer rejects
  cached        Boolean  @default(false)
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([checkType, valueHash, createdAt])
}

model KycCheckCache {
  // Composite key: checkType + valueHash. Composite primary key so we don't
  // accidentally collide hashes across check types.
  checkType    String
  valueHash    String   @db.VarChar(64)
  provider     String
  // Provider-specific normalised result. BVN: { firstName, lastName,
  // dateOfBirth, gender, phone? }. CAC: { businessName, registrationNumber,
  // status, directors[] }. Address: { lat, lng, formattedAddress, components }.
  result       Json
  cachedAt     DateTime @default(now())

  @@id([checkType, valueHash])
  @@index([cachedAt])
}

model CustomCategory {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  label      String
  value      String
  icon       String   @default("pricetag-outline")
}

model Customer {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  businessId      String?
  business        Business?   @relation(fields: [businessId], references: [id])
  name            String
  phone           String?
  totalOwed       Float       @default(0)
  reminderEnabled Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  debts           Debt[]
  sales           Sales[]
  transactions    Transaction[]
  invoices        Invoice[]

  @@unique([userId, phone])
  @@index([userId, businessId])
  @@index([businessId, updatedAt])
}

model Debt {
  id         String        @id @default(uuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float
  paidAmount Float         @default(0)
  paid       Boolean       @default(false)
  note       String        @default("")
  date       DateTime      @default(now())
  payments   DebtPayment[]

  @@index([customerId, paid])
}

model DebtPayment {
  id     String   @id @default(uuid())
  debtId String
  debt   Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  amount Float
  note   String   @default("")
  date   DateTime @default(now())
}

model Payable {
  id           String           @id @default(uuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creditorName String
  category     String           @default("other")
  amount       Float
  paidAmount   Float            @default(0)
  dueDate      DateTime?
  note         String?
  date         DateTime         @default(now())
  paid         Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  payments     PayablePayment[]

  @@index([businessId, paid])
}

model PayablePayment {
  id        String   @id @default(uuid())
  payableId String
  payable   Payable  @relation(fields: [payableId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  date      DateTime @default(now())
}

model BusinessDebt {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId      String?
  business        Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  name            String
  type            String   @default("other")
  originalAmount  Float
  remainingAmount Float
  dueDate         DateTime?
  note            String?
  status          String   @default("unpaid")
  reminderEnabled Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, businessId])
  @@index([userId, status])
  @@index([businessId, updatedAt])
}

model Sales {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  businessId     String?
  business       Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  amount         Float
  paymentMethod        String    @default("cash")
  isCredit             Boolean   @default(false)
  notes                String?
  matchedTransactionId String?
  recordedBy           String?
  recordedByName       String?
  date                 DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId, businessId])
  @@index([businessId, date])
  @@index([businessId, updatedAt])
}

model Expense {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String?
  business      Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  category      String    @default("other")
  amount        Float
  paymentMethod String    @default("cash")
  date          DateTime  @default(now())
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, businessId])
  @@index([businessId, date])
  @@index([businessId, updatedAt])
}

model Transaction {
  id             String    @id @default(uuid())
  businessId     String
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type           String
  amount         Float
  description    String?
  category       String?
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  date           DateTime
  paymentMethod        String    @default("cash")
  matchedSaleId        String?
  matchedCustomerId    String?
  recordedBy           String?
  recordedByName       String?
  userId               String?
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  source               String?
  // Deterministic idempotency key for Anchor-sourced money movement (transfers,
  // bills, inbound credits). The @@unique below makes "record this once" atomic:
  // a duplicate insert fails with P2002 instead of double-spending/double-crediting.
  // Null for manual/offline transactions (Postgres allows many nulls).
  reference            String?
  currency             String    @default("NGN")   // base currency at time of record; per-business default
  flagSeverity         String?    // null | "low" | "medium" | "high"
  complianceStatus     String    @default("clean") // "clean" | "flagged" | "held" | "cleared"
  // Outbound-transfer fee charged to the user (₦51/₦101 pass-through + margin).
  // `amount` stays the transfer amount so income/expense reports are truthful;
  // the fee is its own field. Zero for everything that isn't an external transfer.
  fee                  Float     @default(0)
  feeBreakdown         Json?     // { nip, stampDuty, platform }
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([businessId, reference])
  @@index([businessId, date])
  @@index([userId])
  @@index([businessId, updatedAt])
  @@index([complianceStatus, flagSeverity])
}

// Idempotency ledger for inbound Anchor webhooks. We insert the provider event
// id BEFORE acting on it; a duplicate delivery hits the @unique and is skipped,
// so a credit/debit is processed exactly once regardless of re-delivery.
model ProcessedWebhook {
  id         String   @id @default(uuid())
  eventId    String   @unique
  type       String?
  receivedAt DateTime @default(now())
}

model InventoryItem {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId     String?
  business       Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  name           String
  description    String?
  unit           String    @default("piece")
  price          Float
  cost           Float?
  quantity       Int       @default(0)
  lowStockAlert  Int       @default(5)
  category       String?
  sku            String?
  barcode        String?
  image          String?
  lastRestocked  DateTime?
  createdBy      String?
  createdByName  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, businessId])
  @@index([businessId, updatedAt])
}

model RecurringExpense {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String?
  business      Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  category      String    @default("other")
  amount        Float
  paymentMethod String    @default("cash")
  notes         String?
  frequency     String    @default("monthly")
  nextDue       DateTime
  active        Boolean   @default(true)
  // ── Auto-debit (off by default; backwards-compatible) ──────────────────
  autoSend             Boolean   @default(false)
  authorizedAt         DateTime?
  payeeAccountNumber   String?
  payeeBankCode        String?
  payeeBankName        String?
  payeeAccountName     String?
  lastAutoSendAt       DateTime?
  lastAutoSendStatus   String?   // "ok" | "insufficient_balance" | "blocked_aml" | "anchor_error" | "above_cap" | "skipped_paused"
  lastAutoSendRef      String?
  consecutiveFailures  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, active])
  @@index([nextDue, active])
  @@index([active, autoSend])
}

model OtpCode {
  id         String   @id @default(uuid())
  identifier String
  type       String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([identifier, type])
}

model Reminder {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String?
  business      Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  targetId      String?
  type          String    @default("debt")
  amount        Float     @default(0)
  recipientName String    @default("")
  phone         String?
  message       String?   @db.Text
  channel       String    @default("sms")
  status        String    @default("pending")
  scheduledFor  DateTime
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, scheduledFor])
  @@index([userId])
}

model Suggestion {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("feature")
  content   String   @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id             String           @id @default(uuid())
  businessId     String
  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  userId         String
  invoiceNumber  String
  type           String           @default("invoice") // "invoice" | "quote" (quotes convert to invoices)
  status         InvoiceStatus    @default(DRAFT)
  issueDate      String
  dueDate        String?
  currency       String           @default("NGN")
  subtotal       Float            @default(0)
  taxRate        Float            @default(0)
  taxAmount      Float            @default(0)
  discountType   String?
  discountValue  Float            @default(0)
  discountAmount Float            @default(0)
  total          Float            @default(0)
  amountPaid     Float            @default(0)
  notes          String?
  terms          String?
  template       String           @default("classic")
  items          InvoiceItem[]
  payments       InvoicePayment[]
  shareLink      InvoiceShareLink?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([businessId, userId])
  @@index([businessId, status])
  @@index([businessId, updatedAt])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Float    @default(1)
  rate        Float    @default(0)
  amount      Float    @default(0)
}

model InvoicePayment {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  method    String   @default("cash")
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model InvoiceShareLink {
  id        String   @id @default(cuid())
  invoiceId String   @unique
  token     String   @unique
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([token])
}

enum Plan {
  FREE
  PREMIUM
}

enum Role {
  USER
  ADMIN
}

enum AccountType {
  OWNER
  STAFF
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

// Append-only audit log — used for every state-changing or security-relevant
// action. Reviewed by admins via the compliance dashboard.
model AuditLog {
  id           String   @id @default(cuid())
  actorType    String   // "user" | "admin" | "system"
  actorId      String?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  userAgent    String?
  metadata     Json?
  severity     String   @default("info") // "info" | "warn" | "alert"
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([severity, createdAt])
  @@index([createdAt])
  @@index([action, createdAt])
}

// Open-review queue for the compliance team. Rules engine writes here; admins
// transition status to cleared/escalated/frozen.
model ComplianceFlag {
  id            String   @id @default(uuid())
  userId        String
  businessId    String?
  transactionId String?
  ruleCode      String
  severity      String   // "low" | "medium" | "high"
  description   String
  metadata      Json
  status        String   @default("open") // "open" | "cleared" | "escalated" | "frozen"
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewerNote  String?
  createdAt     DateTime @default(now())

  @@index([status, severity, createdAt])
  @@index([userId])
  @@index([transactionId])
}

// ── Observability ─────────────────────────────────────────────────────────────
// In-house error tracking, health/analytics history snapshots, cron heartbeats
// and alert-cooldown state. See server/src/utils/{errorTracker,metrics,alerts}.js.

model ErrorGroup {
  id          String       @id @default(uuid())
  fingerprint String       @unique           // hash(name + normalized message + top frame)
  name        String                          // error class / name
  message     String                          // representative message
  where       String?                         // top in-app stack frame or route
  level       String       @default("error")  // "error" | "fatal" | "warn"
  status      String       @default("open")   // "open" | "resolved" | "ignored"
  count       Int          @default(0)
  firstSeen   DateTime     @default(now())
  lastSeen    DateTime     @default(now())
  events      ErrorEvent[]

  @@index([status, lastSeen])
}

model ErrorEvent {
  id         String     @id @default(uuid())
  groupId    String
  group      ErrorGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  message    String
  stack      String?    @db.Text
  route      String?
  method     String?
  statusCode Int?
  userId     String?
  ip         String?
  userAgent  String?
  context    Json?      // redacted request context (no secrets/PII)
  createdAt  DateTime   @default(now())

  @@index([groupId, createdAt])
}

model MetricSnapshot {
  id      String   @id @default(uuid())
  kind    String                            // "health" | "analytics"
  takenAt DateTime @default(now())
  data    Json

  @@index([kind, takenAt])
}

model CronHeartbeat {
  name       String   @id                    // cron identifier
  lastRunAt  DateTime
  lastStatus String   @default("ok")          // "ok" | "error"
  lastError  String?
}

model AlertState {
  key         String   @id                    // alert rule key
  lastFiredAt DateTime
  lastValue   String?
}
